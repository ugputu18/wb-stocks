# WB seller token with access to Statistics and Supplies categories.
# Generate in WB seller cabinet: Settings → Access to API.
WB_TOKEN=

# Base URL for WB Statistics API (used by stocks import).
WB_STATS_BASE_URL=https://statistics-api.wildberries.ru

# Base URL for WB FBW Supplies API (used by supplies update).
WB_SUPPLIES_BASE_URL=https://supplies-api.wildberries.ru

# SQLite DB file where stock snapshots are stored.
DATABASE_PATH=./data/wb-stocks.sqlite

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
