# WB seller token with access to Statistics and Supplies categories.
# Generate in WB seller cabinet: Settings → Access to API.
WB_TOKEN=

# Base URL for WB Statistics API (used by stocks import).
WB_STATS_BASE_URL=https://statistics-api.wildberries.ru

# Base URL for WB FBW Supplies API (used by supplies update).
WB_SUPPLIES_BASE_URL=https://supplies-api.wildberries.ru

# Base URL for WB Common API (used by warehouse tariffs update).
WB_COMMON_BASE_URL=https://common-api.wildberries.ru

# SQLite DB file where stock snapshots are stored.
# In the GCP deploy this points to /srv/wb-stocks/data/wb-stocks.sqlite
# (the data persistent disk). Locally — keep the relative path.
DATABASE_PATH=./data/wb-stocks.sqlite

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Forecast UI HTTP server bind. Keep on loopback in production —
# nginx fronts the public port 80 (see deploy/gcp/nginx/forecast-ui.conf).
FORECAST_UI_HOST=127.0.0.1
FORECAST_UI_PORT=3847

# When set, `/api/*` requires `Authorization: Bearer <FORECAST_UI_TOKEN>`.
# In the GCP deploy this is populated from Secret Manager by
# deploy/gcp/scripts/fetch-secrets.sh.
FORECAST_UI_TOKEN=
