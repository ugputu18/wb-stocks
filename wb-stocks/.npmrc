# Pin Node.js for all pnpm scripts in this project so it does not depend on the
# system `node` on PATH (which on macOS may be a Homebrew v18) or on a manual
# `nvm use`. pnpm downloads this exact version into its own store and uses it
# for `pnpm install` (incl. native module rebuild) and every `pnpm run …`.
#
# Keep the version in sync with `.nvmrc` (major). Bump on Node LTS releases.
use-node-version=22.21.1
