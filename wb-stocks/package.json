{
  "name": "wb-stocks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WB warehouse stocks snapshot loader",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "import:stocks": "node --env-file=.env --import tsx src/cli/importStocks.ts",
    "import:own-stocks": "node --env-file=.env --import tsx scripts/import-own-warehouse-state.ts",
    "update:wb-supplies": "node --env-file=.env --import tsx scripts/update-wb-supplies.ts",
    "forecast:sales-mvp": "node --env-file=.env --import tsx scripts/run-sales-forecast-mvp.ts",
    "serve:forecast-ui": "node --env-file=.env --import tsx scripts/serve-forecast-ui.ts",
    "report:warehouse-macro-coverage": "node --env-file=.env --import tsx scripts/report-warehouse-macro-coverage.ts",
    "panda:forecast-ui": "panda codegen --cwd forecast-ui-client && panda cssgen --cwd forecast-ui-client",
    "prepare": "pnpm run panda:forecast-ui",
    "dev:forecast-ui-client": "pnpm run panda:forecast-ui && vite --config forecast-ui-client/vite.config.ts",
    "build:forecast-ui-client": "pnpm run panda:forecast-ui && vite build --config forecast-ui-client/vite.config.ts",
    "typecheck:forecast-ui-client": "tsc --project forecast-ui-client/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "better-sqlite3": "^12.9.0",
    "csv-parse": "^6.2.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.10.0",
    "@preact/preset-vite": "^2.10.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "preact": "^10.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
